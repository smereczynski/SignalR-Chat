@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model UsersEditModel
@{
    ViewData["Title"] = Localizer["EditUser"];
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">@Localizer["EditUser"] — <code>@Model.UserName</code></h2>
        <form method="post">
            <input type="hidden" asp-for="UserName" />
            <div class="mb-3">
                <label class="form-label">@Localizer["FullName"]</label>
                <input asp-for="Input.FullName" class="form-control" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">@Localizer["Email"]</label>
                <input asp-for="Input.Email" type="email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">@Localizer["Mobile"]</label>
                <input asp-for="Input.MobileNumber" type="tel" class="form-control" />
                <span asp-validation-for="Input.MobileNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">@Localizer["Upn"]</label>
                <input asp-for="Input.Upn" type="email" class="form-control" placeholder="user@domain.com (optional)" />
                <span asp-validation-for="Input.Upn" class="text-danger"></span>
                <small class="form-text text-muted">User Principal Name for Microsoft Entra ID authentication. Leave empty for OTP-only users.</small>
            </div>
            <div class="mb-3">
                <label class="form-label">@Localizer["PreferredLanguage"]</label>
                <input asp-for="Input.PreferredLanguage" class="form-control" placeholder="en, pl, de-DE …" />
                <span asp-validation-for="Input.PreferredLanguage" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" asp-for="Input.Enabled" class="form-check-input" id="enabledCheck" />
                <label class="form-check-label" for="enabledCheck">@Localizer["EnabledQuestion"]</label>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                <a asp-page="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
