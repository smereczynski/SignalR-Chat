@page "{userName}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model UsersAssignRoomsModel
@{
    ViewData["Title"] = "Assign Dispatch Center";
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Assign Dispatch Center to @Model.UserName</h2>
        <form method="post">
            <input type="hidden" asp-for="UserName" />
            <div class="mb-3">
                <label asp-for="SelectedDispatchCenterId" class="form-label">Dispatch Center</label>
                <select asp-for="SelectedDispatchCenterId" class="form-select">
                    <option value="">No dispatch center</option>
                    @foreach (var dispatchCenter in Model.DispatchCenters)
                    {
                        <option value="@dispatchCenter.Id">@dispatchCenter.Name (@dispatchCenter.Country)</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                <a asp-page="Index" class="btn btn-secondary">@Localizer["Back"]</a>
            </div>
        </form>
    </div>
</div>
