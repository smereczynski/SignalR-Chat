@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model Chat.Web.Pages.Admin.DispatchCenters.DispatchCentersCreateModel
@{
    ViewData["Title"] = Localizer["CreateDispatchCenter"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">@Localizer["CreateDispatchCenter"]</h2>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label">@Localizer["Name"]</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Country" class="form-label">@Localizer["Country"]</label>
                <input asp-for="Input.Country" class="form-control" />
                <span asp-validation-for="Input.Country" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Input.IfMain" class="form-check-input" />
                <label asp-for="Input.IfMain" class="form-check-label">@Localizer["MainDispatchCenter"]</label>
            </div>

            <partial
                name="_CorrespondingDispatchCentersChecklist"
                model="Model.AllDispatchCenters"
                view-data='new ViewDataDictionary(ViewData) { ["SelectedIds"] = new HashSet<string>(StringComparer.OrdinalIgnoreCase), ["IdPrefix"] = "dc-create" }' />

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["Create"]</button>
                <a asp-page="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>
