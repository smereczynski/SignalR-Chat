@page "{id}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model Chat.Web.Pages.Admin.DispatchCenters.DispatchCentersEditModel
@{
    ViewData["Title"] = Localizer["EditDispatchCenter"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">@Localizer["EditDispatchCenter"]</h2>

        <form method="post">
            <input type="hidden" asp-for="Id" />

            <partial name="_DispatchCenterBasicFields" model="Model.Input"
                view-data='new ViewDataDictionary(ViewData) { TemplateInfo = { HtmlFieldPrefix = "Input" } }' />

            <partial
                name="_CorrespondingDispatchCentersChecklist"
                model="Model.AllDispatchCenters"
                view-data='new ViewDataDictionary(ViewData) { ["SelectedIds"] = new HashSet<string>(Model.Input.CorrespondingDispatchCenterIds ?? new List<string>(), StringComparer.OrdinalIgnoreCase), ["IdPrefix"] = "dc-edit" }' />

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                <a asp-page="AssignUsers" asp-route-id="@Model.Id" class="btn btn-outline-primary">@Localizer["AssignUsers"]</a>
                <a asp-page="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>

        <hr class="my-4" />

        <h4>@Localizer["ImpactSummary"]</h4>

        <div class="row g-3">
            <div class="col-md-4">
                <h6 class="text-muted">@Localizer["AssignedUsers"] (@Model.AssignedUsers.Count)</h6>
                @if (Model.AssignedUsers.Count == 0)
                {
                    <p class="text-muted small">—</p>
                }
                else
                {
                    <ul class="list-unstyled small">
                        @foreach (var u in Model.AssignedUsers)
                        {
                            <li>
                                <i class="bi bi-person"></i>
                                @(u.FullName ?? u.UserName)
                                @if (!u.Enabled)
                                {
                                    <span class="badge bg-secondary ms-1">@Localizer["Inactive"]</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="col-md-4">
                <h6 class="text-muted">@Localizer["ReciprocalPairs"] (@Model.ReciprocalPairs.Count)</h6>
                @if (Model.ReciprocalPairs.Count == 0)
                {
                    <p class="text-muted small">—</p>
                }
                else
                {
                    <ul class="list-unstyled small">
                        @foreach (var dc in Model.ReciprocalPairs)
                        {
                            <li><i class="bi bi-diagram-3"></i> @dc.Name (@dc.Country)</li>
                        }
                    </ul>
                }
            </div>

            <div class="col-md-4">
                <h6 class="text-muted">@Localizer["DerivedPairRooms"] (@Model.DerivedPairRooms.Count)</h6>
                @if (Model.DerivedPairRooms.Count == 0)
                {
                    <p class="text-muted small">—</p>
                }
                else
                {
                    <ul class="list-unstyled small">
                        @foreach (var r in Model.DerivedPairRooms)
                        {
                            <li>
                                <i class="bi bi-chat-dots"></i>
                                @(r.DisplayName ?? r.Name)
                                @if (r.IsActive)
                                {
                                    <span class="badge bg-success ms-1">@Localizer["Active"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark ms-1">@Localizer["Inactive"]</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
