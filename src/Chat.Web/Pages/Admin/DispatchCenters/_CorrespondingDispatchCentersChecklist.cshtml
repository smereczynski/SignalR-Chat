@using System
@using System.Collections.Generic
@using System.Linq
@using Chat.Web.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model IEnumerable<DispatchCenter>
@{
    var selectedIds = ViewData["SelectedIds"] as ISet<string>
                      ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var idPrefix = ViewData["IdPrefix"] as string ?? "dc";
    var dispatchCenters = Model?.ToList() ?? new List<DispatchCenter>();
}

<div class="mb-3">
    <label class="form-label">@Localizer["CorrespondingDispatchCenters"]</label>
    @if (!dispatchCenters.Any())
    {
        <div class="text-muted">@Localizer["NoDispatchCentersAvailable"]</div>
    }
    else
    {
        @for (int i = 0; i < dispatchCenters.Count; i++)
        {
            var dc = dispatchCenters[i];
            var isChecked = selectedIds.Contains(dc.Id);
            <div class="form-check">
                <input
                    type="checkbox"
                    name="Input.CorrespondingDispatchCenterIds"
                    value="@dc.Id"
                    class="form-check-input"
                    id="@idPrefix-@i"
                    @(isChecked ? "checked" : "") />
                <label class="form-check-label" for="@idPrefix-@i">@dc.Name (@dc.Country)</label>
            </div>
        }
    }
</div>
