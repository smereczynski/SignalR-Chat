@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model Chat.Web.Pages.Admin.DispatchCenters.DispatchCentersIndexModel
@{
    ViewData["Title"] = Localizer["DispatchCenters"];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-page="Create" class="btn btn-primary">@Localizer["CreateDispatchCenter"]</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Country"]</th>
                <th>@Localizer["Main"]</th>
                <th>@Localizer["CorrespondingDispatchCenters"]</th>
                <th>@Localizer["AssignedUsers"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dc in Model.DispatchCenters)
            {
                <tr>
                    <td>@dc.Name</td>
                    <td>@dc.Country</td>
                    <td>
                        @if (dc.IfMain)
                        {
                            <span class="badge bg-success">@Localizer["Yes"]</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Localizer["No"]</span>
                        }
                    </td>
                    <td class="text-muted">@string.Join(", ", dc.CorrespondingDispatchCenterIds ?? new List<string>())</td>
                    <td>@((dc.Users ?? new List<string>()).Count)</td>
                    <td class="d-flex gap-1">
                        <a asp-page="Edit" asp-route-id="@dc.Id" class="btn btn-sm btn-outline-primary">@Localizer["Edit"]</a>
                        <a asp-page="AssignUsers" asp-route-id="@dc.Id" class="btn btn-sm btn-outline-secondary">@Localizer["AssignUsers"]</a>
                        <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="id" value="@dc.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this dispatch center?');">@Localizer["Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
