@page "{id}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Chat.Web.Resources.SharedResources> Localizer
@model Chat.Web.Pages.Admin.DispatchCenters.DispatchCentersAssignUsersModel
@{
    ViewData["Title"] = Localizer["AssignUsers"];
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">@Localizer["AssignUsersToDispatchCenter", Model.DispatchCenterName]</h2>

        <form method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                @for (int i = 0; i < Model.AllUsers.Count; i++)
                {
                    var user = Model.AllUsers[i];
                    var isChecked = Model.SelectedUsers.Contains(user.UserName, StringComparer.OrdinalIgnoreCase);
                    <div class="form-check">
                        <input type="checkbox" name="SelectedUsers" value="@user.UserName" class="form-check-input" id="user-@i" @(isChecked ? "checked" : "") />
                        <label class="form-check-label" for="user-@i">@user.UserName (@user.FullName)</label>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                <a asp-page="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">@Localizer["Edit"]</a>
                <a asp-page="Index" class="btn btn-secondary">@Localizer["Back"]</a>
            </div>
        </form>
    </div>
</div>
